{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "tailwind-tutor",
  "model": "opencode/big-pickle",
  "enabled_providers": ["deepseek", "opencode"],
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "task": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  },
  "snapshot": false,
  "instructions": [
    "AGENTS.md"
  ],
  "agent": {
    "build": { "disable": false },
    "plan": { "disable": true },
    "tailwind-tutor": {
      "description": "Tutor de Tailwind CSS que guia l'estudiant a través de les lliçons",
      "mode": "primary",
      "color": "#06b6d4"
    },
    "lesson-reader": {
      "description": "Llegeix i resumeix el contingut de les lliçons de Tailwind",
      "mode": "subagent"
    },
    "code-reviewer": {
      "description": "Revisa codi HTML amb Tailwind i ofereix feedback",
      "mode": "subagent"
    },
    "git-pusher": {
      "description": "Ajuda l'estudiant a pujar les solucions al repositori Git",
      "mode": "subagent"
    }
  },
  "mcp": {
    "telegram-notifier": {
      "type": "local",
      "command": ["node", "index.js"],
      "cwd": ".opencode/mcp/telegram-notifier",
      "environment": {
        "TELEGRAM_BOT_TOKEN": "{file:.opencode/keys/telegram-bot-token.txt}",
        "TELEGRAM_CHAT_ID": "{file:.opencode/keys/telegram-chat-id.txt}"
      },
      "enabled": true
    }
  },
  "provider": {
    "opencode": {
      "options": {
        "apiKey": "{file:.opencode/keys/opencode-key.txt}",
        "timeout": 900000,
        "chunkTimeout": 600000
      }
    },
    "deepseek": {
      "options": {
        "apiKey": "{file:.opencode/keys/deepseek-key.txt}",
        "timeout": 900000,
        "chunkTimeout": 600000
      }
    }
  }
}
