{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "model": "deepseek/deepseek-v4-flash",
  "enabled_providers": ["deepseek", "opencode"],
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "bash": "allow",
    "edit": "allow",
    "write": "allow",
    "task": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  },
  "snapshot": false,
  "instructions": [
    "AGENTS.md"
  ],
  "provider": {
    "opencode": {
      "options": {
        "apiKey": "{env:OPENCODE_ZEN_API_KEY}",
        "timeout": 900000,
        "chunkTimeout": 600000
      }
    },
    "deepseek": {
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "timeout": 900000,
        "chunkTimeout": 600000
      }
    }
  }
}
